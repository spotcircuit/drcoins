# Authorize.Net Credentials (card payments)
AUTHORIZENET_API_LOGIN_ID=your_api_login_id
AUTHORIZENET_TRANSACTION_KEY=your_transaction_key
AUTHORIZENET_ENV=sandbox  # or 'production'
NEXT_PUBLIC_AUTHORIZENET_CLIENT_KEY=your_public_client_key
NEXT_PUBLIC_AUTHORIZENET_API_LOGIN_ID=your_api_login_id
NEXT_PUBLIC_AUTHORIZENET_ENV=sandbox

# Plaid — bank checkout uses Plaid Transfer UI (ACH debit originated by Plaid, not Authorize.Net).
# Dashboard: https://dashboard.plaid.com — enable Transfer; create a Link customization with Account Select = one account (see Plaid Transfer UI docs).
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
# sandbox | development | production
PLAID_ENV=sandbox
# Link customization name from Dashboard (often "default" if you only have one).
PLAID_LINK_CUSTOMIZATION_NAME=default
# Optional: funding account ID from Plaid Dashboard → Accounts → Account ID column (defaults to your default funding account if unset).
# PLAID_TRANSFER_FUNDING_ACCOUNT_ID=
#
# Transfer webhooks (ACH lifecycle): Plaid Dashboard → Team → Webhooks → add a Transfer webhook URL:
#   {NEXT_PUBLIC_APP_URL}/api/webhooks/plaid
# Item / Link webhooks: same public URL is sent on /link/token/create as `webhook` when NEXT_PUBLIC_APP_URL is set
# (needed for Plaid onboarding “Set up webhooks” + /sandbox/item/fire_webhook). Optional Dashboard copy:
#   Developers → Webhooks (or Team → Webhooks) — use the same URL if Plaid asks for a default dev webhook.
# @see https://plaid.com/docs/api/webhooks/#introduction-to-webhooks
# @see https://plaid.com/docs/transfer/reconciling-transfers/
# Local tunnel testing only (never in production): if your tunnel cannot receive Plaid-Verification, you may set:
# PLAID_WEBHOOK_SKIP_VERIFY=true
#
# Trigger a Sandbox TRANSFER_EVENTS_UPDATE to NEXT_PUBLIC_APP_URL/api/webhooks/plaid (requires dev server + PLAID_ENV=sandbox):
#   npm run plaid:fire-webhook
#
# One-shot ITEM webhook (Plaid onboarding NEW_ACCOUNTS_AVAILABLE) — needs access_token from **Link** (Account Select v2),
# not from npm run plaid:sandbox-access-token. Capture after one Sandbox checkout (dev only, then unset):
#   PLAID_DEBUG_SAVE_SANDBOX_ACCESS_TOKEN_FILE=tmp/plaid-sandbox-access-token.txt
#   PLAID_DEBUG_SKIP_ITEM_REMOVE_SANDBOX=true
# Then run (reads tmp/plaid-sandbox-access-token.txt automatically): npm run plaid:fire-item-new-accounts
# Or pass the token: npm run plaid:fire-item-new-accounts -- access-sandbox-...
# or PLAID_SANDBOX_ACCESS_TOKEN=access-sandbox-... in .env.local
#
# Create a fresh Sandbox Item and print access_token (no app logs — run locally):
#   npm run plaid:sandbox-access-token
#
# Call /accounts/get in Sandbox (Plaid checklist "Test Item endpoint") — same token resolution as fire-item-new-accounts:
#   npm run plaid:accounts-get
# Optional: PLAID_SANDBOX_INSTITUTION_ID=ins_... if the default list fails

# ForumPay (crypto payments) - optional
# Get API keys from ForumPay Dashboard: Account > API, Webhooks, Widgets
# Sandbox: https://sandbox.api.forumpay.com/pay/v2  Production: https://api.forumpay.com/pay/v2
FORUMPAY_API_BASE_URL=https://sandbox.api.forumpay.com/pay/v2
FORUMPAY_API_USER=your_forumpay_api_user
FORUMPAY_API_SECRET=your_forumpay_api_secret
FORUMPAY_POS_ID=web
# Payment Link API (Create Payment Link - used for crypto checkout redirect)
# Optional: if Payment API uses a different base URL than FORUMPAY_API_BASE_URL, set it here
# FORUMPAY_PAYMENT_API_BASE_URL=https://sandbox.api.forumpay.com/pay/v2
# Set webhook in ForumPay Dashboard to: https://yourdomain.com/api/webhooks/forumpay

# PostgreSQL Database
DATABASE_URL=postgresql://username:password@localhost:5432/drcoins?schema=public

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin Authentication
ADMIN_PASSWORD=your-admin-password-here

# Email (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

# Vercel Blob Storage (Required for production on Vercel)
# Get this from: https://vercel.com/dashboard -> Storage -> Create Blob Store
# Then go to .env.production tab and copy the BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Optional: Vercel Environment (automatically set by Vercel)
# VERCEL=1
